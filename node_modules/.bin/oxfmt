#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/wesley.niels/Field Hockey Team Manager App/node_modules/.pnpm/oxfmt@0.2.0/node_modules/oxfmt/node_modules:/Users/wesley.niels/Field Hockey Team Manager App/node_modules/.pnpm/oxfmt@0.2.0/node_modules:/Users/wesley.niels/Field Hockey Team Manager App/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/wesley.niels/Field Hockey Team Manager App/node_modules/.pnpm/oxfmt@0.2.0/node_modules/oxfmt/node_modules:/Users/wesley.niels/Field Hockey Team Manager App/node_modules/.pnpm/oxfmt@0.2.0/node_modules:/Users/wesley.niels/Field Hockey Team Manager App/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../oxfmt/bin/oxfmt" "$@"
else
  exec node  "$basedir/../oxfmt/bin/oxfmt" "$@"
fi
